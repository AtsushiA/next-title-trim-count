<?xml version="1.0"?>
<ruleset name="Next Title TrimCount">
    <description>Custom ruleset for Next Title TrimCount</description>

    <!-- 対象ファイル -->
    <file>./next-title-trim-count.php</file>

    <!-- 除外 -->
    <exclude-pattern>./vendor/*</exclude-pattern>
    <exclude-pattern>./node_modules/*</exclude-pattern>
    <exclude-pattern>./tests/*</exclude-pattern>
    <exclude-pattern>./build/*</exclude-pattern>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- 日本語コメントはピリオド・感嘆符・疑問符で終わらないため除外 -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ShortNotCapital"/>
        <exclude name="Generic.Commenting.DocComment.ShortNotCapital"/>
        <!-- @package タグは不要（プラグインヘッダーで代替） -->
        <exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
    </rule>

    <!-- PHP互換性チェック -->
    <rule ref="PHPCompatibilityWP"/>

    <!-- PHP バージョン（Requires PHP: 7.4 に合わせる） -->
    <config name="testVersion" value="7.4-"/>

    <!-- テキストドメイン -->
    <config name="text_domain" value="next-title-trim-count"/>

    <!-- プレフィックス -->
    <config name="prefixes" value="next_title_trim_count"/>
    <config name="minimum_wp_version" value="6.0"/>
</ruleset>
